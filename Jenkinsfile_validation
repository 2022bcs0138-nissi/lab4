pipeline {
    agent any

    environment {
        IMAGE_NAME = "2022bcs0138nissiveronika/wine-mlops:latest"
        CONTAINER_NAME = "wine_test_container"
        PORT = "8000"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Pull Image') {
            steps {
                sh "docker pull ${IMAGE_NAME}"
            }
        }

        stage('Run Container') {
            steps {
                sh "docker run -d -p ${PORT}:8000 --name ${CONTAINER_NAME} ${IMAGE_NAME}"
            }
        }

        stage('Wait for Service Readiness') {
            steps {
                script {
                    timeout(time: 40, unit: 'SECONDS') {
                        waitUntil {
                            def status = sh(
                                script: "curl -s http://localhost:${PORT}/docs",
                                returnStatus: true
                            )
                            return (status == 0)
                        }
                    }
                }
            }
        }

        stage('Valid Inference Test') {
            steps {
                script {
                    def response = sh(
                        script: "curl -s -X POST http://localhost:${PORT}/predict -H 'Content-Type: application/json' -d @test_inputs/valid.json",
                        returnStdout: true
                    ).trim()

                    echo "Valid Response: ${response}"

                    if (!response.contains("wine_quality")) {
                        error("wine_quality field missing!")
                    }
                }
            }
        }

        stage('Invalid Inference Test') {
            steps {
                script {
                    def code = sh(
                        script: "curl -s -o /dev/null -w \"%{http_code}\" -X POST http://localhost:${PORT}/predict -H 'Content-Type: application/json' -d @test_inputs/invalid.json",
                        returnStdout: true
                    ).trim()

                    echo "Invalid Status Code: ${code}"

                    if (code == "200") {
                        error("Invalid input should not return 200!")
                    }
                }
            }
        }

        stage('Stop Container') {
            steps {
                sh "docker stop ${CONTAINER_NAME} || true"
                sh "docker rm ${CONTAINER_NAME} || true"
            }
        }
    }
}
